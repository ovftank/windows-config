{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 20000,
        "tail_turns": 6
    },
    "default_agent": "ask",
    "formatter": true,
    "permission": {
        "skill": {
            "customize-opencode": "deny"
        }
    },
    "lsp": {},
    "provider": {
        "anthropic": {
            "whitelist": [
                "claude-opus-4-8",
                "claude-opus-4-7",
                "claude-sonnet-4-6"
            ]
        },
        "openai": {
            "models": {
                "gpt-5.4": {
                    "id": "gpt-5.4",
                    "name": "GPT-5.4",
                    "limit": {
                        "context": 258000,
                        "input": 258000,
                        "output": 32000
                    }
                },
                "gpt-5.5": {
                    "id": "gpt-5.5",
                    "name": "GPT-5.5",
                    "limit": {
                        "context": 258000,
                        "input": 258000,
                        "output": 32000
                    }
                }
            }
        }
    },
    "share": "disabled",
    "shell": "bash",
    "snapshot": true,
    "tool_output": {
        "max_bytes": 20000,
        "max_lines": 600
    },
    "watcher": {
        "ignore": [
            "**/node_modules/**"
        ]
    }
}